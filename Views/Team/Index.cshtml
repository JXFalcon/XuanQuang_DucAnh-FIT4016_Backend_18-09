@model IEnumerable<Web_BongDa.Models.Team>

@{
    ViewData["Title"] = "Bảng Xếp Hạng Ngoại Hạng";
}
<link rel="stylesheet" href="/Index.css" />
<div class="standing-container py-5">
    <div class="container">
        <div class="row mb-4 align-items-center">
            <div class="col-md-6 text-center text-md-start">
                <h2 class="fw-black text-dark mb-0" style="letter-spacing: -1px;">
                    <span class="badge bg-primary me-2">LIVE</span> BẢNG XẾP HẠNG 2024
                </h2>
                <p class="text-muted small mb-0">Cập nhật lần cuối: @DateTime.Now.ToString("HH:mm dd/MM/yyyy")</p>
            </div>
            <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                <a href="/Team/UpdateMatch" class="btn btn-dark btn-lg shadow rounded-pill px-4">
                    <i class="bi bi-gear-fill me-2"></i>Quản lý kết quả
                </a>
            </div>
        </div>

        <div class="card standing-card shadow-lg">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="text-center">Pos</th>
                                <th>Câu Lạc Bộ</th>
                                <th class="text-center">Trận</th>
                                <th class="text-center">T - H - L</th>
                                <th class="text-center">Hiệu Số</th>
                                <th class="text-center">Điểm</th>
                                <th class="text-center">Thẻ Phạt</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int rank = 1;
                                foreach (var t in Model)
                                {
                                    <tr class="team-row">
                                        <td class="text-center">
                                            <span class="rank-circle">@rank</span>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="logo-container me-3">

                                                </div>
                                    <td>
    <div class="d-flex align-items-center">
        <div class="logo-container me-3">
            <img src="@t.Logo" style="width:35px; height:35px; object-fit:contain;" />
        </div>
        <div>
            <a href="/Team/Players/@t.Id" class="fw-bold d-block text-dark text-decoration-none">
                @t.Name

                
            </a>
            <span class="text-muted" style="font-size: 0.7rem;">CHAMPIONS LEAGUE</span>
        </div>
    </div>
</td>
                                            </div>
                                        </td>
                                        <td class="text-center fw-bold">@t.Played</td>
                                        <td class="text-center">
                                            <span class="badge bg-success-subtle text-success px-2">@t.Won</span>
                                            <span class="badge bg-secondary-subtle text-secondary px-2">@t.Drawn</span>
                                            <span class="badge bg-danger-subtle text-danger px-2">@t.Lost</span>
                                        </td>
                                        <td class="text-center">
                                            <div class="progress" style="height: 6px; width: 60px; margin: 0 auto;">
                                                <div class="progress-bar bg-primary" style="width: @(t.Points * 2)%"></div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="points-badge fw-black text-primary">@t.Points</span>
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex justify-content-center gap-1">
                                                <div class="bg-warning rounded px-2 text-dark fw-bold" style="font-size: 0.8rem;">@t.YellowCards</div>
                                                <div class="bg-danger rounded px-2 text-white fw-bold" style="font-size: 0.8rem;">@t.RedCards</div>
                                            </div>
                                        </td>
                                    </tr>
                                    rank++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

